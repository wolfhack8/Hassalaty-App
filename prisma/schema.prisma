generator client { provider = "prisma-client-js" }

datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum Role { PARENT CHILD }
enum TransactionType { INCOME EXPENSE SAVING }
enum GoalStatus { IN_PROGRESS ACHIEVED }
enum RewardStatus { PENDING APPROVED REJECTED CLAIMED }
enum ReportPeriod { WEEKLY MONTHLY }

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(PARENT)
  isDemo        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  childProfile  ChildProfile?
  parentLinks   ParentChild[] @relation("ParentLinks")
  childLinks    ParentChild[] @relation("ChildLinks")
  rewards       Reward[] @relation("RewardCreator")
}

model ChildProfile {
  id          String @id @default(cuid())
  userId      String @unique
  points      Int    @default(0)
  level       Int    @default(1)
  avatar      String?
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  goals       SavingsGoal[]
  redemptions RedeemedReward[]
  challenges  WeeklyChallenge[]
  pointEvents PointEvent[]
  reports     FinancialReport[]
}

model ParentChild {
  id        String @id @default(cuid())
  parentId  String
  childId   String
  createdAt DateTime @default(now())
  parent    User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child     User @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)
  @@unique([parentId, childId])
  @@index([childId])
}

model Transaction {
  id             String @id @default(cuid())
  childProfileId String
  amount         Float
  type           TransactionType
  category       String
  description    String?
  occurredAt     DateTime @default(now())
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  @@index([childProfileId, occurredAt])
}

model SavingsGoal {
  id             String @id @default(cuid())
  childProfileId String
  title          String
  targetAmount   Float
  currentAmount  Float @default(0)
  status         GoalStatus @default(IN_PROGRESS)
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
}

model Reward {
  id          String @id @default(cuid())
  parentId    String
  title       String
  description String?
  pointsCost  Int
  isRealWorld Boolean @default(true)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  parent      User @relation("RewardCreator", fields: [parentId], references: [id], onDelete: Cascade)
  redemptions RedeemedReward[]
}

model RedeemedReward {
  id             String @id @default(cuid())
  rewardId       String
  childProfileId String
  pointsSpent    Int
  status         RewardStatus @default(PENDING)
  redeemedAt     DateTime @default(now())
  reward         Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  @@index([childProfileId, redeemedAt])
}

model PointEvent {
  id             String @id @default(cuid())
  childProfileId String
  points         Int
  reason         String
  createdAt      DateTime @default(now())
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
}

model WeeklyChallenge {
  id             String @id @default(cuid())
  childProfileId String
  title          String
  description    String
  pointsReward   Int
  isCompleted    Boolean @default(false)
  deadline       DateTime
  createdAt      DateTime @default(now())
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
}

model FinancialReport {
  id             String @id @default(cuid())
  childProfileId String
  period         ReportPeriod
  periodStart    DateTime
  summary        String @db.Text
  data           Json
  createdAt      DateTime @default(now())
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
}

model Account {
  id String @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? @db.Text
  access_token String? @db.Text
  expires_at Int?
  token_type String?
  scope String?
  id_token String? @db.Text
  session_state String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}
model Session {
  id String @id @default(cuid())
  sessionToken String @unique
  userId String
  expires DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model VerificationToken {
  identifier String
  token String @unique
  expires DateTime
  @@unique([identifier, token])
}

